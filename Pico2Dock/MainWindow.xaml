<ui:FluentWindow
    x:Class="Pico2Dock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Pico2Dock"
    xmlns:markd="clr-namespace:MarkdView.Controls;assembly=MarkdView"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Pico2Dock"
    MinWidth="500"
    MinHeight="750"
    Background="Transparent"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <Grid x:Name="MainContent">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ui:TitleBar Grid.Row="0" Height="27">
                <ui:TitleBar.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:ImageIcon Margin="15,5,0,5" Source="/src/icon.ico" />
                        <ui:TextBlock Margin="5,0,0,0" VerticalAlignment="Center">Pico2Dock</ui:TextBlock>
                    </StackPanel>
                </ui:TitleBar.Header>
            </ui:TitleBar>

            <ui:DynamicScrollViewer
                Grid.Row="1"
                Margin="10,20,10,20"
                Padding="15,0,15,0"
                CanContentScroll="True"
                IsScrollingVertically="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>


                    <ui:Card>
                        <ui:Card.Background>
                            <ImageBrush
                                ImageSource="/src/banner.jpg"
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Stretch="UniformToFill" />
                        </ui:Card.Background>
                        <StackPanel Grid.Row="0">
                            <StackPanel Orientation="Horizontal">
                                <ui:ImageIcon
                                    Height="30"
                                    Margin="0,3,10,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Source="/src/icon.ico" />
                                <ui:TextBlock
                                    FontTypography="Title"
                                    Foreground="White"
                                    Text="Pico2Dock"
                                    TextWrapping="Wrap" />
                                <ui:TextBlock
                                    x:Name="VersionText"
                                    Margin="20,15,0,0"
                                    FontTypography="BodyStrong"
                                    Foreground="White"
                                    Text="Version"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ui:TextBlock
                                FontTypography="Subtitle"
                                Foreground="White"
                                Text="Convert the APK app from normal floating to Dashboard Dock for Pico 4, alike File Manager."
                                TextWrapping="Wrap" />
                            <ui:TextBlock
                                FontTypography="BodyStrong"
                                Foreground="White"
                                Text="Allow to multitasking while in fullscreen immersive app."
                                TextWrapping="Wrap" />

                            <StackPanel
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Orientation="Horizontal">

                                <ui:TextBlock
                                    Margin="6"
                                    FontTypography="Caption"
                                    Foreground="White"
                                    Text="Made by H@mer" />
                                <ui:HyperlinkButton
                                    Content="Github Page"
                                    Foreground="NavajoWhite"
                                    Icon="{ui:SymbolIcon Symbol=Globe24,
                                                         Filled=False}"
                                    NavigateUri="https://github.com/chaixshot/Pico2Dock" />
                            </StackPanel>
                        </StackPanel>
                    </ui:Card>


                    <ui:Card
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="5">
                        <Grid>
                            <ui:ListView
                                Name="DropBox"
                                Height="200"
                                AllowDrop="True"
                                DragLeave="DropBox_DragLeave"
                                DragOver="DropBox_DragOver"
                                Drop="DropBox_Drop"
                                ItemsSource="{Binding Path=Files}"
                                KeyUp="DropBox_KeyUp"
                                MouseDoubleClick="DropBox_MouseDoubleClick"
                                ScrollViewer.CanContentScroll="True"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto" />
                            <ui:Button
                                x:Name="DropBoxButton"
                                Width="{Binding ActualWidth, ElementName=DropBox, Mode=OneWay}"
                                Height="{Binding ActualHeight, ElementName=DropBox, Mode=OneWay}"
                                Padding="0"
                                AllowDrop="True"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                Click="DropBox_Click"
                                Content="Drag and drop APK file here, or click here to choose a file"
                                Cursor="Hand"
                                DragLeave="DropBox_DragLeave"
                                DragOver="DropBox_DragOver"
                                Drop="DropBox_Drop"
                                FontWeight="Bold"
                                Opacity="0.4"
                                ToolTip="Click or drop file here" />
                        </Grid>
                    </ui:Card>

                    <StackPanel
                        Grid.Row="2"
                        Margin="0,3,0,0"
                        Orientation="Horizontal">
                        <ui:Button
                            x:Name="StartButton"
                            Click="StartProcess"
                            Content="Start"
                            ToolTip="Start contert process" />

                        <ui:Button
                            x:Name="CancleButton"
                            Margin="5,0,0,0"
                            Click="CancleProcess"
                            Content="Cancle"
                            IsEnabled="False"
                            ToolTip="Terminate processing task" />

                        <ui:Button
                            x:Name="ClearButton"
                            Margin="5,0,0,0"
                            Click="ClearFiles"
                            Content="Clear"
                            ToolTip="Clear all files" />

                        <ui:Button
                            x:Name="DeleteButton"
                            Margin="5,0,0,0"
                            Click="DeleteFiles"
                            Content="Delete"
                            ToolTip="Delete current select file" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,30,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar
                                x:Name="StatusProgressBar"
                                Height="20"
                                Value="40" />
                            <ui:TextBlock
                                x:Name="PercentText"
                                Margin="10,0,0,0"
                                HorizontalAlignment="Center"
                                Foreground="White" />
                        </Grid>

                        <ui:Card Padding="0">
                            <markd:MarkdownViewer
                                x:Name="StatusText"
                                Height="200"
                                HorizontalContentAlignment="Left"
                                EnableStreaming="False"
                                EnableSyntaxHighlighting="True"
                                FontFamily="Segoe UI"
                                FontSize="14"
                                ScrollViewer.CanContentScroll="True"
                                ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"
                                UseTransparentCanvas="True" />
                        </ui:Card>

                        <ui:Button
                            x:Name="OutputButton"
                            Margin="0,3,0,0"
                            Click="OpenOutput"
                            Content="Open patched folder"
                            ToolTip="Open output folder in file explorer" />
                    </StackPanel>
                </Grid>
            </ui:DynamicScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
